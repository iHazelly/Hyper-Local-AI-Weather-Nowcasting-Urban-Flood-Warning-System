import json
import boto3
import pickle
import pandas as pd
import requests
from datetime import datetime, timedelta, timezone
from boto3.dynamodb.conditions import Key

# --- System Configuration ---
S3_BUCKET = 'flood-alert-model-st125894'
MODEL_KEY = 'xgboost_rain_model.pkl'
DYNAMODB_TABLE = 'WeatherTelemetry'
LINE_TOKEN = '<your Line token>'
MAE_THRESHOLD = 2.0 

s3_client = boto3.client('s3')
dynamodb = boto3.resource('dynamodb')
table = dynamodb.Table(DYNAMODB_TABLE)

def lambda_handler(event, context):
    # 1. Retrieve model from S3 Data Lake
    local_model_path = '/tmp/model.pkl'
    s3_client.download_file(S3_BUCKET, MODEL_KEY, local_model_path)
    with open(local_model_path, 'rb') as f:
        model = pickle.load(f)

    # 2. Query historical feature matrix (last 7 days)
    tz_bkk = timezone(timedelta(hours=7))
    seven_days_ago = (datetime.now(tz_bkk) - timedelta(days=7)).strftime('%Y-%m-%dT%H:00:00')

    response = table.query(
        KeyConditionExpression=Key('node_id').eq('master_grid') & Key('timestamp').gte(seven_days_ago)
    )
    items = response.get('Items', [])
    if not items:
        return {"status": "no_data"}

    # Align dataframe columns with model expectations
    df = pd.DataFrame(items).sort_values('timestamp')
    timestamps = df['timestamp'].tolist()
    features = df.drop(columns=['node_id', 'timestamp'])
    
    if hasattr(model, 'feature_names_in_'):
        features = features.reindex(columns=model.feature_names_in_, fill_value=0)
    features = features.astype(float)

    # 3. Generate retrospective predictions
    predictions = model.predict(features)
    pred_1h = [float(p[0]) if hasattr(p, '__len__') else float(p) for p in predictions]

    # 4. Fetch ground-truth meteorological data via API
    url = "https://api.open-meteo.com/v1/forecast?latitude=14.06&longitude=100.61&hourly=rain&timezone=Asia/Bangkok&past_days=7"
    api_res = requests.get(url).json()
    actual_rain_map = dict(zip(api_res['hourly']['time'], api_res['hourly']['rain']))

    # 5. Compute Mean Absolute Error (MAE) for Concept Drift detection
    errors = []
    for i, ts in enumerate(timestamps):
        ts_key = ts[:16] # Format: YYYY-MM-DDTHH:mm
        actual_val = actual_rain_map.get(ts_key)
        if actual_val is not None:
            errors.append(abs(pred_1h[i] - actual_val))

    if not errors:
        return {"status": "no_match"}

    mae = sum(errors) / len(errors)

    # 6. Trigger automated MLOps alert if threshold is breached
    if mae > MAE_THRESHOLD:
        msg = (f"\n🚨 [MLOps Alert] Concept Drift Detected\n"
               f"7-Day MAE: {mae:.2f} mm (Threshold: {MAE_THRESHOLD} mm)\n"
               f"Action: Model retraining required.")
        headers = {'Authorization': f'Bearer {LINE_TOKEN}', 'Content-Type': 'application/x-www-form-urlencoded'}
        requests.post("https://notify-api.line.me/api/notify", headers=headers, data={'message': msg})
        
    return {"status": "success", "mae": mae}